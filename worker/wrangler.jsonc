{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "openvibe-worker",
  "main": "src/index.ts",
  "compatibility_date": "2026-03-17",
  "assets": {
    "binding": "ASSETS",
    "directory": "./public",
  },
  "observability": {
    "enabled": true,
  },
  "compatibility_flags": ["nodejs_compat"],
}
